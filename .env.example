# Copy this file to .env and fill in real values. Never commit .env itself.

# Adzuna API (https://developer.adzuna.com) - required
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# RapidAPI JSearch (optional, only if JSearch source is enabled)
RAPIDAPI_KEY=

# Telegram Bot (message @BotFather to create a bot, then get your chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Path to the resume file used by resume_parser.py
RESUME_FILE_PATH=my-resume/HAZIQ_RESUME_UPDATED_V001.pdf
