# Copy this file to .env and fill in real values. Never commit .env itself.

# Adzuna API (https://developer.adzuna.com) - required
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# RapidAPI JSearch (optional, only if JSearch source is enabled)
RAPIDAPI_KEY=

# Telegram Bot (message @BotFather to create a bot, then get your chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Path(s) to the resume file(s) used by resume_parser.py.
# One path, or multiple comma-separated paths to merge (e.g. a detailed CV +
# a simpler CV - skills/experience from all listed files get combined).
RESUME_FILE_PATH=my-resume/HAZIQ_RESUME_UPDATED_V001.pdf,my-resume/Muhammad_Haziq_Nazeer_Resume_TWO.pdf
